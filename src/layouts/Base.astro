---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, description = '赛博阿漆的博客 - AI学习与技术分享', image, type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL || '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI, 人工智能, 机器学习, 深度学习, 技术博客" />
    <meta name="author" content="赛博阿漆" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={image} />}
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
    
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href={`${base}rss.xml`} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <div class="nav-brand">
          <a href={`${base}`}>🔫 赛博阿漆</a>
        </div>
        <div class="nav-links">
          <a href={`${base}`}>首页</a>
          <a href={`${base}posts/`}>文章</a>
          <a href={`${base}tags/`}>标签</a>
          <a href={`${base}about/`}>关于</a>
          <a href={`${base}rss.xml`} target="_blank" rel="noopener">RSS</a>
        </div>
        <div class="nav-actions">
          <button id="theme-toggle" aria-label="切换主题">🌙</button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-section">
          <h4>关于</h4>
          <p>赛博阿漆的AI学习笔记与技术分享</p>
        </div>
        <div class="footer-section">
          <h4>链接</h4>
          <a href="https://github.com/shenlv7" target="_blank" rel="noopener">GitHub</a>
          <a href={`${base}rss.xml`}>RSS订阅</a>
        </div>
        <div class="footer-section">
          <h4>联系方式</h4>
          <p>2056440151@qq.com</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 赛博阿漆 · Powered by Astro · 保持学习，持续进化</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;
      
      const saved = localStorage.getItem('theme');
      if (saved) html.setAttribute('data-theme', saved);
      
      toggle?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        toggle.textContent = next === 'dark' ? '🌙' : '☀️';
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #1a1a2e;
    --accent: #e94560;
    --accent-light: #ff6b6b;
    --muted: #666;
    --border: #e1e5e9;
    --code-bg: #f6f8fa;
    --card-bg: #ffffff;
    --shadow: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);
    --shadow-hover: 0 14px 28px rgba(0,0,0,0.25), 0 10px 10px rgba(0,0,0,0.22);
  }

  [data-theme="dark"] {
    --bg: #0d1117;
    --text: #c9d1d9;
    --accent: #ff6b6b;
    --accent-light: #ff8e8e;
    --muted: #8b949e;
    --border: #21262d;
    --code-bg: #161b22;
    --card-bg: #161b22;
    --shadow: 0 1px 3px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.4);
    --shadow-hover: 0 14px 28px rgba(0,0,0,0.5), 0 10px 10px rgba(0,0,0,0.4);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    transition: background 0.3s, color 0.3s;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-light); }

  header {
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand a {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--muted);
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--accent); }

  .nav-actions button {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem;
    cursor: pointer;
    font-size: 1.1rem;
    transition: all 0.2s;
  }

  .nav-actions button:hover {
    background: var(--border);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    min-height: 70vh;
  }

  footer {
    background: var(--card-bg);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .footer-section h4 {
    color: var(--text);
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .footer-section p, .footer-section a {
    color: var(--muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    text-align: center;
    padding: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }
    
    .nav-links {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    
    main {
      padding: 1rem;
    }
    
    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
