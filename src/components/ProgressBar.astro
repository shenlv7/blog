---
// ProgressBar.astro - AI学习系列进度条
interface Props {
  current: number;
  total: number;
  levels?: { label: string; range: [number, number]; emoji: string }[];
}

const { current, total, levels = [
  { label: '基础篇', range: [1, 4], emoji: '🌱' },
  { label: '中级篇', range: [5, 8], emoji: '🌿' },
  { label: '进阶篇', range: [9, 12], emoji: '🌳' },
] } = Astro.props;
const percentage = Math.round((current / total) * 100);
---

<div class="progress-container">
  <div class="progress-header">
    <span class="progress-title">📚 学习进度</span>
    <span class="progress-text">{current}/{total} 期 · {percentage}%</span>
  </div>
  
  <div class="progress-bar">
    <div class="progress-fill" style={`width: ${percentage}%`}>
      <span class="progress-shine"></span>
    </div>
  </div>

  <div class="progress-levels">
    {levels.map(level => {
      const completed = Math.max(0, Math.min(level.range[1], current) - level.range[0] + 1);
      const totalInLevel = level.range[1] - level.range[0] + 1;
      const isActive = current >= level.range[0];
      const isComplete = completed >= totalInLevel;
      return (
        <div class={`level ${isActive ? 'active' : ''} ${isComplete ? 'complete' : ''}`}>
          <span class="level-emoji">{level.emoji}</span>
          <span class="level-label">{level.label}</span>
          <span class="level-count">{completed}/{totalInLevel}</span>
          {isComplete && <span class="level-check">✅</span>}
        </div>
      );
    })}
  </div>
</div>

<style>
  .progress-container {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .progress-title {
    font-weight: 600;
    font-size: 1.1rem;
  }
  .progress-text {
    color: var(--accent);
    font-weight: 600;
  }
  .progress-bar {
    height: 12px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 6px;
    transition: width 1s ease-out;
    position: relative;
    overflow: hidden;
  }
  .progress-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: shine 2s infinite;
  }
  @keyframes shine {
    to { left: 100%; }
  }
  .progress-levels {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }
  .level {
    flex: 1;
    text-align: center;
    padding: 0.75rem;
    border-radius: 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    opacity: 0.5;
    transition: all 0.3s;
  }
  .level.active {
    opacity: 1;
    border-color: var(--accent);
  }
  .level.complete {
    opacity: 1;
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.05);
  }
  .level-emoji {
    display: block;
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .level-label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }
  .level-count {
    font-size: 0.8rem;
    color: var(--muted);
  }
  .level-check {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.9rem;
  }
  @media (max-width: 768px) {
    .progress-levels { flex-direction: column; }
  }
</style>
