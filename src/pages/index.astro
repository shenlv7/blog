---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const tags = [...new Set(posts.flatMap(post => post.data.tags || []))];
const base = import.meta.env.BASE_URL;
---

<Base title="赛博阿漆的AI学习博客">
  <section class="hero">
    <div class="hero-content">
      <h1>🚀 AI学习之路</h1>
      <p class="hero-subtitle">从零开始，系统学习人工智能与机器学习</p>
      <p class="hero-desc">记录学习历程，分享技术见解，一起探索AI的无限可能</p>
      
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">{posts.length}</span>
          <span class="stat-label">篇文章</span>
        </div>
        <div class="stat">
          <span class="stat-number">{tags.length}</span>
          <span class="stat-label">个标签</span>
        </div>
        <div class="stat">
          <span class="stat-number">12</span>
          <span class="stat-label">期系列</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href={`${base}posts/`} class="btn btn-primary">开始阅读</a>
        <a href={`${base}tags/`} class="btn btn-secondary">浏览标签</a>
      </div>
    </div>
  </section>

  <section class="featured">
    <h2>📚 最新文章</h2>
    <div class="posts-grid">
      {posts.slice(0, 6).map(post => (
        <article class="post-card">
          <div class="post-meta">
            <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
            {post.data.tags?.[0] && <span class="post-tag">{post.data.tags[0]}</span>}
          </div>
          <h3><a href={`${base}posts/${post.id}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <a href={`${base}posts/${post.id}`} class="read-more">阅读全文 →</a>
        </article>
      ))}
    </div>
    <div class="view-all">
      <a href={`${base}posts/`} class="btn btn-outline">查看所有文章</a>
    </div>
  </section>

  <section class="series">
    <h2>🎯 AI学习系列</h2>
    <div class="series-grid">
      <div class="series-card">
        <h3>🌱 基础篇</h3>
        <p>机器学习核心概念、深度学习入门、神经网络架构、数据工程</p>
        <span class="series-count">4期</span>
      </div>
      <div class="series-card">
        <h3>🌿 中级篇</h3>
        <p>NLP自然语言处理、计算机视觉、强化学习、生成对抗网络</p>
        <span class="series-count">4期</span>
      </div>
      <div class="series-card">
        <h3>🌳 进阶篇</h3>
        <p>Transformer架构、大语言模型原理、微调与RLHF、多模态AI</p>
        <span class="series-count">4期</span>
      </div>
    </div>
  </section>

  <section class="about">
    <h2>👨‍💻 关于博主</h2>
    <div class="about-content">
      <p>赛博阿漆，一个热爱AI技术的学习者。在这里记录我的学习历程，分享技术见解，希望能帮助到同样在AI路上探索的你。</p>
      <div class="about-links">
        <a href="https://github.com/shenlv7" target="_blank" rel="noopener">GitHub</a>
        <a href="mailto:2056440151@qq.com">邮箱联系</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    background: linear-gradient(135deg, var(--card-bg), var(--border));
    border-radius: 16px;
    margin-bottom: 4rem;
  }
  .hero-content { max-width: 800px; margin: 0 auto; }
  .hero h1 { font-size: 3rem; margin-bottom: 1rem; }
  .hero-subtitle { font-size: 1.3rem; color: var(--muted); margin-bottom: 0.5rem; }
  .hero-desc { color: var(--muted); margin-bottom: 2rem; }
  .hero-stats { display: flex; justify-content: center; gap: 3rem; margin-bottom: 2rem; }
  .stat { text-align: center; }
  .stat-number { display: block; font-size: 2rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-size: 0.9rem; color: var(--muted); }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; }
  .btn { display: inline-block; padding: 0.8rem 1.5rem; border-radius: 8px; font-weight: 600; transition: all 0.2s; }
  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:hover { background: var(--accent-light); transform: translateY(-2px); color: white; }
  .btn-secondary { background: var(--card-bg); color: var(--text); border: 2px solid var(--border); }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
  .btn-outline { background: transparent; color: var(--accent); border: 2px solid var(--accent); }
  .btn-outline:hover { background: var(--accent); color: white; }
  .featured { margin-bottom: 4rem; }
  .featured h2 { font-size: 2rem; margin-bottom: 2rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
  .post-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; transition: all 0.2s; }
  .post-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; font-size: 0.9rem; color: var(--muted); }
  .post-tag { background: var(--accent); color: white; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.8rem; }
  .post-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; }
  .post-card h3 a { color: var(--text); text-decoration: none; }
  .post-card h3 a:hover { color: var(--accent); }
  .post-card p { color: var(--muted); font-size: 0.95rem; line-height: 1.5; margin-bottom: 1rem; }
  .read-more { color: var(--accent); font-weight: 500; font-size: 0.95rem; }
  .read-more:hover { text-decoration: underline; }
  .view-all { text-align: center; }
  .series { margin-bottom: 4rem; }
  .series h2 { font-size: 2rem; margin-bottom: 2rem; }
  .series-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .series-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; text-align: center; transition: all 0.2s; }
  .series-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .series-card h3 { font-size: 1.3rem; margin-bottom: 0.8rem; }
  .series-card p { color: var(--muted); margin-bottom: 1rem; line-height: 1.5; }
  .series-count { background: var(--accent); color: white; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.9rem; }
  .about { text-align: center; padding: 3rem; background: var(--card-bg); border-radius: 12px; border: 1px solid var(--border); }
  .about h2 { font-size: 2rem; margin-bottom: 1.5rem; }
  .about-content p { color: var(--muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 1.5rem; }
  .about-links { display: flex; gap: 1rem; justify-content: center; }
  .about-links a { padding: 0.6rem 1.2rem; border: 2px solid var(--border); border-radius: 8px; color: var(--text); transition: all 0.2s; }
  .about-links a:hover { border-color: var(--accent); color: var(--accent); }
  @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .hero-stats { gap: 1.5rem; } .hero-actions { flex-direction: column; align-items: center; } .posts-grid { grid-template-columns: 1fr; } }
</style>
