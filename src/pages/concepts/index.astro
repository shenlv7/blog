<style>
  .concepts-page { max-width: 1100px; margin: 0 auto; }

  .hero {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--card-bg), var(--border));
    border-radius: 16px;
    margin-bottom: 3rem;
  }
  .hero-badge {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .hero h1 { font-size: 2.8rem; margin-bottom: 0.8rem; }
  .hero-desc { color: var(--muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem; }

  .progress-section { max-width: 400px; margin: 0 auto 2rem; }
  .progress-info { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.9rem; }
  .progress-num { font-weight: 700; color: var(--accent); }
  .progress-bar { height: 10px; background: var(--border); border-radius: 5px; overflow: hidden; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent-light)); border-radius: 5px; transition: width 1s ease-out; }

  .hero-stats { display: flex; justify-content: center; gap: 3rem; }
  .stat-item { text-align: center; }
  .stat-num { display: block; font-size: 1.8rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-size: 0.85rem; color: var(--muted); }

  .category-section { margin-bottom: 3rem; }
  .category-header {
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    background: var(--card-bg);
    border-radius: 0 12px 12px 0;
  }
  .category-title { display: flex; align-items: center; gap: 0.75rem; }
  .cat-emoji { font-size: 1.5rem; }
  .category-title h2 { font-size: 1.5rem; margin: 0; }
  .cat-count {
    background: var(--accent);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .cat-desc { color: var(--muted); margin: 0.3rem 0 0 0; font-size: 0.95rem; }

  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  .concept-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.2s;
  }
  .concept-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }
  .card-number {
    color: white;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .card-difficulty {
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .concept-card h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .concept-card h3 a { color: var(--text); text-decoration: none; }
  .concept-card h3 a:hover { color: var(--accent); }
  .card-desc {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-time { font-size: 0.8rem; color: var(--muted); }
  .card-link { color: var(--accent); font-weight: 500; font-size: 0.9rem; }
  .card-link:hover { text-decoration: underline; }

  .empty-category {
    text-align: center;
    padding: 2rem;
    background: var(--card-bg);
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--muted);
  }

  .cta-section {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--card-bg);
    border-radius: 16px;
    border: 1px solid var(--border);
  }
  .cta-section h2 { text-align: center; margin-bottom: 2rem; }
  .tips-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
  .tip-card {
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    text-align: center;
  }
  .tip-emoji { font-size: 2rem; display: block; margin-bottom: 0.8rem; }
  .tip-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .tip-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.5; }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2rem; }
    .hero-stats { gap: 2rem; }
    .concepts-grid { grid-template-columns: 1fr; }
    .tips-grid { grid-template-columns: 1fr; }
  }
</style>
