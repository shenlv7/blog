      <div class="progress-section">
        <div class="progress-info">
          <span>发布进度</span>
          <span class="progress-num">{publishedCount} / {totalConcepts}</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" style={`width: ${progressPercent}%`}></div>
        </div>
      </div>

