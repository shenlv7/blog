---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const base = '/blog/';

// 筛选AI核心概念系列
const conceptPosts = allPosts
  .filter(p => p.data.series === 'ai-concepts')
  .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));

// 难度映射
const difficultyConfig: Record<string, { label: string; color: string; bg: string }> = {
  beginner: { label: '入门', color: '#10b981', bg: 'rgba(16, 185, 129, 0.1)' },
  intermediate: { label: '进阶', color: '#f59e0b', bg: 'rgba(245, 158, 11, 0.1)' },
  advanced: { label: '高级', color: '#ef4444', bg: 'rgba(239, 68, 68, 0.1)' },
};

function estimateReadingTime(content: string): number {
  const chineseChars = (content.match(/[\u4e00-\u9fff]/g) || []).length;
  const englishWords = content.replace(/[\u4e00-\u9fff]/g, '').match(/\b\w+\b/g)?.length || 0;
  return Math.ceil(chineseChars / 450 + englishWords / 200);
}

function getPostsInRange(start: number, end: number) {
  return conceptPosts.filter(p => {
    const order = p.data.seriesOrder;
    return order !== undefined && order >= start && order <= end;
  });
}

const totalConcepts = 43;
const publishedCount = conceptPosts.length;
const progressPercent = Math.round((publishedCount / totalConcepts) * 100);

// 分类数据
const cat1 = getPostsInRange(1, 8);
const cat2 = getPostsInRange(9, 16);
const cat3 = getPostsInRange(17, 24);
const cat4 = getPostsInRange(25, 32);
const cat5 = getPostsInRange(33, 37);
const cat6 = getPostsInRange(38, 43);
---

