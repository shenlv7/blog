        <div class="stat-item">
          <span class="stat-num">{publishedCount}</span>
          <span class="stat-label">已发布</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">{totalConcepts - publishedCount}</span>
          <span class="stat-label">待发布</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">6</span>
          <span class="stat-label">分类板块</span>
        </div>
      </div>
    </section>

    <!-- 基础概念 -->
    <section class="category-section">
      <div class="category-header" style="border-left: 4px solid #3b82f6">
        <div class="category-title">
          <span class="cat-emoji">🧠</span>
          <h2>基础概念</h2>
          <span class="cat-count">{cat1.length}/8</span>
        </div>
        <p class="cat-desc">理解AI的最小知识集</p>
      </div>
      <div class="concepts-grid">
        {cat1.map(post => {
          const slug = post.id.replace(/\.md$/, '');
          const diff = post.data.difficulty || 'beginner';
          const diffInfo = difficultyConfig[diff];
          const readTime = estimateReadingTime(post.body || '');
          return (
            <article class="concept-card">
              <div class="card-top">
                <span class="card-number" style="background: #3b82f6">{String(post.data.seriesOrder).padStart(2, '0')}</span>
                <span class="card-difficulty" style={`color: ${diffInfo.color}; background: ${diffInfo.bg}`}>{diffInfo.label}</span>
              </div>
