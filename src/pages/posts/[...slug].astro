---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.tags?.some(tag => post.data.tags?.includes(tag)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const contentLength = post.body?.length || 0;
const readingTime = Math.max(1, Math.ceil(contentLength / 300));
---

<Base title={post.data.title} description={post.data.description} type="article">
  <article class="post-article">
    <header class="post-header">
      <div class="post-meta">
        <time>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="reading-time">⏱️ 约 {readingTime} 分钟</span>
      </div>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <a href={`/tags#${tag}`} class="post-tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="post-nav">
        <a href="/posts" class="back-link">← 返回文章列表</a>
      </div>

      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <h3>📖 相关文章</h3>
          <div class="related-grid">
            {relatedPosts.map(related => (
              <a href={`/posts/${related.id}`} class="related-item">
                <h4>{related.data.title}</h4>
                <p>{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="share-section">
        <h3>📢 分享文章</h3>
        <div class="share-buttons">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" class="share-btn twitter">
            Twitter
          </a>
          <button onclick={`navigator.clipboard.writeText(window.location.href); this.textContent='已复制！'; setTimeout(() => this.textContent='复制链接', 2000)`} class="share-btn copy">
            复制链接
          </button>
        </div>
      </div>
    </footer>
  </article>
</Base>

<style>
  .post-article { max-width: 800px; margin: 0 auto; }
  .post-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; color: var(--muted); font-size: 0.95rem; }
  .post-header h1 { font-size: 2.5rem; line-height: 1.3; margin-bottom: 1rem; color: var(--text); }
  .post-description { font-size: 1.2rem; color: var(--muted); line-height: 1.6; margin-bottom: 1.5rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .post-tag { background: var(--accent); color: white; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; }
  .post-tag:hover { background: var(--accent-light); transform: scale(1.05); }
  .post-content { line-height: 1.8; font-size: 1.1rem; }
  .post-content :global(h2) { font-size: 1.8rem; margin: 2.5rem 0 1rem; color: var(--text); border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; }
  .post-content :global(h3) { font-size: 1.4rem; margin: 2rem 0 0.8rem; color: var(--text); }
  .post-content :global(p) { margin: 1rem 0; color: var(--text); }
  .post-content :global(ul), .post-content :global(ol) { margin: 1rem 0; padding-left: 2rem; }
  .post-content :global(li) { margin: 0.5rem 0; color: var(--text); }
  .post-content :global(blockquote) { border-left: 4px solid var(--accent); padding: 1rem 1.5rem; margin: 1.5rem 0; background: var(--border); border-radius: 0 8px 8px 0; }
  .post-content :global(blockquote p) { margin: 0; font-style: italic; }
  .post-content :global(pre) { background: var(--code-bg); padding: 1.5rem; border-radius: 8px; overflow-x: auto; margin: 1.5rem 0; font-size: 0.95rem; line-height: 1.5; }
  .post-content :global(code) { background: var(--code-bg); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.9em; }
  .post-content :global(pre code) { background: none; padding: 0; }
  .post-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; }
  .post-content :global(a) { color: var(--accent); text-decoration: underline; }
  .post-content :global(strong) { color: var(--text); font-weight: 600; }
  .post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .post-nav { margin-bottom: 3rem; }
  .back-link { color: var(--accent); text-decoration: none; font-weight: 500; }
  .back-link:hover { text-decoration: underline; }
  .related-posts { margin-bottom: 3rem; }
  .related-posts h3 { font-size: 1.3rem; margin-bottom: 1rem; color: var(--text); }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; }
  .related-item { display: block; padding: 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; transition: all 0.2s; }
  .related-item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .related-item h4 { color: var(--text); margin-bottom: 0.5rem; font-size: 1rem; }
  .related-item p { color: var(--muted); font-size: 0.9rem; margin: 0; line-height: 1.4; }
  .share-section h3 { font-size: 1.3rem; margin-bottom: 1rem; color: var(--text); }
  .share-buttons { display: flex; gap: 1rem; }
  .share-btn { padding: 0.6rem 1.2rem; border: 2px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text); cursor: pointer; font-size: 0.95rem; text-decoration: none; transition: all 0.2s; }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); }
  .share-btn.twitter:hover { background: #1da1f2; color: white; border-color: #1da1f2; }
  @media (max-width: 768px) { .post-header h1 { font-size: 1.8rem; } .post-meta { flex-direction: column; align-items: flex-start; gap: 0.5rem; } .share-buttons { flex-direction: column; } }
</style>
