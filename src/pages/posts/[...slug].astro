---
import Base from '../../layouts/Base.astro';
import ReadingProgressBar from '../../components/ReadingProgressBar.astro';
import BackToTop from '../../components/BackToTop.astro';
import CodeCopy from '../../components/CodeCopy.astro';
import PostNav from '../../components/PostNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const slug = post.id.replace(/\.md$/, '');

const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.tags?.some(tag => post.data.tags?.includes(tag)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// 系列信息
const series = post.data.series;
const seriesOrder = post.data.seriesOrder;
const seriesNames: Record<string, string> = {
  'ai-concepts': 'AI核心概念',
  'ai-learning-01': 'AI学习之路',
};
const seriesName = series ? seriesNames[series] || series : null;
const totalInSeries = series ? allPosts.filter(p => p.data.series === series).length : 0;
---

<Base title={post.data.title} description={post.data.description} type="article">
  <ReadingProgressBar />
  <CodeCopy />
  
  <article class="post-article">
    <header class="post-header">
      {seriesName && seriesOrder && (
        <div class="series-badge">
          <a href={`${base}concepts/`}>{seriesName}</a>
          <span>·</span>
          <span>第 {seriesOrder} 期</span>
          {totalInSeries > 0 && <span>/ 共 {totalInSeries} 期</span>}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      <div class="post-meta">
        <time>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {post.data.difficulty && (
          <span class={`diff-badge diff-${post.data.difficulty}`}>
            {post.data.difficulty === 'beginner' ? '🌱 入门' : post.data.difficulty === 'intermediate' ? '🌿 中级' : '🌳 高级'}
          </span>
        )}
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <a href={`${base}tags#${tag}`} class="post-tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <!-- 系列导航 -->
      <PostNav currentSlug={slug} series={series} seriesOrder={seriesOrder} />

      <!-- 相关文章 -->
      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <h3>📖 相关文章</h3>
          <div class="related-grid">
            {relatedPosts.map(related => (
              <a href={`${base}posts/${related.id.replace(/\.md$/, '')}/`} class="related-item">
                <h4>{related.data.title}</h4>
                <p>{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- 分享 -->
      <div class="share-section">
        <h3>📢 分享文章</h3>
        <div class="share-buttons">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" class="share-btn twitter">
            Twitter
          </a>
          <button onclick={`navigator.clipboard.writeText(window.location.href); this.textContent='已复制！'; setTimeout(() => this.textContent='复制链接', 2000)`} class="share-btn copy">
            复制链接
          </button>
        </div>
      </div>

      <div class="back-link-wrap">
        <a href={`${base}posts/`} class="back-link">← 返回文章列表</a>
      </div>
    </footer>
  </article>
  
  <BackToTop />
</Base>

<style>
  .post-article { max-width: 800px; margin: 0 auto; }
  
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .series-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 0.8rem;
    padding: 0.3rem 0.8rem;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    border-radius: 100px;
  }
  .series-badge a { color: var(--accent); text-decoration: none; font-weight: 600; }
  .series-badge a:hover { text-decoration: underline; }
  .series-badge span { color: var(--muted); }
  
  .post-header h1 { font-size: 2rem; line-height: 1.3; margin-bottom: 0.75rem; color: var(--text); }
  .post-description { font-size: 1.05rem; color: var(--muted); line-height: 1.5; margin-bottom: 1rem; }
  
  .post-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.8rem; color: var(--muted); font-size: 0.9rem; }
  .diff-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-weight: 500;
  }
  .diff-beginner { background: rgba(16, 185, 129, 0.1); color: #10b981; }
  .diff-intermediate { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
  .diff-advanced { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .post-tag { background: var(--accent); color: white; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.85rem; text-decoration: none; transition: all 0.2s; }
  .post-tag:hover { background: var(--accent-light); transform: scale(1.05); }

  .post-content { line-height: 1.8; font-size: 1.05rem; }
  .post-content :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 1rem; color: var(--text); border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; }
  .post-content :global(h3) { font-size: 1.3rem; margin: 2rem 0 0.8rem; color: var(--text); }
  .post-content :global(h4) { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; color: var(--text); }
  .post-content :global(p) { margin: 1rem 0; color: var(--text); }
  .post-content :global(ul), .post-content :global(ol) { margin: 1rem 0; padding-left: 2rem; }
  .post-content :global(li) { margin: 0.5rem 0; color: var(--text); }
  .post-content :global(blockquote) { border-left: 4px solid var(--accent); padding: 1rem 1.5rem; margin: 1.5rem 0; background: color-mix(in srgb, var(--accent) 5%, var(--bg)); border-radius: 0 8px 8px 0; }
  .post-content :global(blockquote p) { margin: 0; font-style: italic; }
  .post-content :global(pre) { background: var(--code-bg); padding: 1.5rem; border-radius: 8px; overflow-x: auto; margin: 1.5rem 0; font-size: 0.9rem; line-height: 1.6; }
  .post-content :global(code) { background: var(--code-bg); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.88em; }
  .post-content :global(pre code) { background: none; padding: 0; font-size: inherit; }
  .post-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; }
  .post-content :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .post-content :global(a:hover) { color: var(--accent-light); }
  .post-content :global(strong) { color: var(--text); font-weight: 600; }
  .post-content :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
  .post-content :global(th), .post-content :global(td) { padding: 0.6rem 1rem; border: 1px solid var(--border); text-align: left; }
  .post-content :global(th) { background: var(--card-bg); font-weight: 600; }

  .post-footer { margin-top: 3rem; }

  .related-posts { margin-top: 3rem; }
  .related-posts h3 { font-size: 1.2rem; margin-bottom: 1rem; color: var(--text); }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .related-item { display: block; padding: 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; transition: all 0.2s; }
  .related-item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .related-item h4 { color: var(--text); margin-bottom: 0.4rem; font-size: 0.95rem; }
  .related-item p { color: var(--muted); font-size: 0.85rem; margin: 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  
  .share-section { margin-top: 3rem; }
  .share-section h3 { font-size: 1.2rem; margin-bottom: 1rem; color: var(--text); }
  .share-buttons { display: flex; gap: 0.75rem; }
  .share-btn { padding: 0.5rem 1rem; border: 1.5px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text); cursor: pointer; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); }
  .share-btn.twitter:hover { background: #1da1f2; color: white; border-color: #1da1f2; }
  
  .back-link-wrap { margin-top: 2rem; text-align: center; }
  .back-link { color: var(--muted); text-decoration: none; font-size: 0.9rem; }
  .back-link:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .post-header h1 { font-size: 1.6rem; }
    .post-meta { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .share-buttons { flex-direction: column; }
  }
</style>
