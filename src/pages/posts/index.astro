---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagCounts = {};
posts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagCounts).sort(([,a], [,b]) => b - a);
---

<Base title="所有文章">
  <div class="posts-page">
    <header class="posts-header">
      <h1>📝 所有文章</h1>
      <p>共 {posts.length} 篇文章，持续更新中</p>
    </header>

    <div class="posts-layout">
      <aside class="tags-sidebar">
        <h3>🏷️ 标签</h3>
        <div class="tags-list">
          {sortedTags.map(([tag, count]) => (
            <a href={`/tags#${tag}`} class="tag-item">
              <span class="tag-name">#{tag}</span>
              <span class="tag-count">{count}</span>
            </a>
          ))}
        </div>
      </aside>

      <main class="posts-list">
        {posts.map((post) => (
          <article class="post-item">
            <div class="post-meta">
              <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="post-tag">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="post-content">
              <h2><a href={`/posts/${post.id}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <a href={`/posts/${post.id}`} class="read-more">阅读全文 →</a>
            </div>
          </article>
        ))}
      </main>
    </div>
  </div>
</Base>

<style>
  .posts-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .posts-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
    border-radius: 16px;
    color: white;
  }

  .posts-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .posts-header p {
    opacity: 0.9;
    font-size: 1.1rem;
  }

  .posts-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 2rem;
  }

  .tags-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .tags-sidebar h3 {
    margin-bottom: 1rem;
    color: var(--text);
    font-size: 1.1rem;
  }

  .tags-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tag-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    border-radius: 8px;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
  }

  .tag-item:hover {
    background: var(--border);
    color: var(--accent);
  }

  .tag-name {
    font-size: 0.9rem;
  }

  .tag-count {
    background: var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.8rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s;
  }

  .post-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-tag {
    background: var(--accent);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  .post-content h2 {
    margin-bottom: 0.8rem;
    font-size: 1.3rem;
  }

  .post-content h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-content h2 a:hover {
    color: var(--accent);
  }

  .post-content p {
    color: var(--muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .read-more {
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .posts-layout {
      grid-template-columns: 1fr;
    }
    
    .tags-sidebar {
      position: static;
      order: -1;
    }
    
    .posts-header h1 {
      font-size: 2rem;
    }
  }
</style>
