---

<Base title="所有文章">
  <div class="posts-page">
    <h1>📝 所有文章</h1>
    <p class="subtitle">共 {posts.length} 篇文章</p>
    
    <SearchBox />

    <div class="posts-list">
      {posts.map(post => {
        const slug = post.id.replace(/\.md$/, '');
        const seriesNum = post.data.seriesOrder;
        const difficulty = seriesNum ? difficultyMap[seriesNum] : undefined;
        return (
        <article class="post-item">
          {post.data.cover && (
            <div class="post-cover-small">
              <img src={post.data.cover} alt={post.data.title} loading="lazy" />
            </div>
          )}
          <div class="post-info">
            <time>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <div class="post-tags">
              {post.data.tags?.map(tag => (
                <TagBadge tag={tag} size="sm" />
              ))}
            </div>
          </div>
          <div class="post-content">
            <div class="post-title-row">
              <h2><a href={`${base}posts/${slug}/`}>{post.data.title}</a></h2>
              {difficulty && <DifficultyBadge difficulty={difficulty} />}
            </div>
            <p>{post.data.description}</p>
            <div class="post-meta-row">
              <span class="read-time">📖 {estimateReadingTime(post.body || '')}分钟阅读</span>
              <a href={`${base}posts/${slug}/`} class="read-more">阅读全文 →</a>
            </div>
          </div>
        </article>
      )})}
    </div>
  </div>
</Base>

<style>
  .posts-page { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--muted); margin-bottom: 2rem; font-size: 1.1rem; }
  .posts-list { display: flex; flex-direction: column; gap: 2rem; }
  .post-item { display: flex; gap: 2rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; transition: all 0.2s; }
  .post-item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .post-cover-small { width: 120px; height: 80px; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
  .post-cover-small img { width: 100%; height: 100%; object-fit: cover; }
  .post-info { min-width: 180px; text-align: right; }
  .post-info time { display: block; color: var(--muted); font-size: 0.95rem; margin-bottom: 0.8rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: flex-end; }
  .post-content { flex: 1; }
  .post-title-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .post-content h2 { font-size: 1.4rem; }
  .post-content h2 a { color: var(--text); text-decoration: none; }
  .post-content h2 a:hover { color: var(--accent); }
  .post-content p { color: var(--muted); line-height: 1.6; margin-bottom: 0.8rem; }
  .post-meta-row { display: flex; justify-content: space-between; align-items: center; }
  .read-time { font-size: 0.85rem; color: var(--muted); }
  .read-more { color: var(--accent); font-weight: 500; }
  .read-more:hover { text-decoration: underline; }
  @media (max-width: 768px) { 
    .post-item { flex-direction: column; gap: 1rem; } 
    .post-info { text-align: left; min-width: auto; } 
    .post-tags { justify-content: flex-start; } 
    .post-cover-small { width: 100%; height: 160px; }
  }
</style>
