---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = import.meta.env.BASE_URL;
---

<Base title="所有文章">
  <div class="posts-page">
    <h1>📝 所有文章</h1>
    <p class="subtitle">共 {posts.length} 篇文章</p>
    
    <div class="posts-list">
      {posts.map(post => (
        <article class="post-item">
          <div class="post-info">
            <time>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <div class="post-tags">
              {post.data.tags?.map(tag => (
                <a href={`${base}tags#${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          </div>
          <div class="post-content">
            <h2><a href={`${base}posts/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <a href={`${base}posts/${post.id}`} class="read-more">阅读全文 →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</Base>

<style>
  .posts-page { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--muted); margin-bottom: 3rem; font-size: 1.1rem; }
  .posts-list { display: flex; flex-direction: column; gap: 2rem; }
  .post-item { display: flex; gap: 2rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; transition: all 0.2s; }
  .post-item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .post-info { min-width: 180px; text-align: right; }
  .post-info time { display: block; color: var(--muted); font-size: 0.95rem; margin-bottom: 0.8rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: flex-end; }
  .tag { background: var(--accent); color: white; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.8rem; text-decoration: none; }
  .tag:hover { background: var(--accent-light); color: white; }
  .post-content { flex: 1; }
  .post-content h2 { font-size: 1.4rem; margin-bottom: 0.5rem; }
  .post-content h2 a { color: var(--text); text-decoration: none; }
  .post-content h2 a:hover { color: var(--accent); }
  .post-content p { color: var(--muted); line-height: 1.6; margin-bottom: 0.8rem; }
  .read-more { color: var(--accent); font-weight: 500; }
  .read-more:hover { text-decoration: underline; }
  @media (max-width: 768px) { .post-item { flex-direction: column; gap: 1rem; } .post-info { text-align: left; min-width: auto; } .post-tags { justify-content: flex-start; } }
</style>
