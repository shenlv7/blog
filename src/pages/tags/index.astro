---
import Base from '../../layouts/Base.astro';
import SearchBox from '../../components/SearchBox.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const ideas = (await getCollection('ideas')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const inventions = (await getCollection('inventions')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const base = '/blog/';

// 构建标签映射
const tagMap = new Map<string, typeof posts>();
posts.forEach(post => {
  post.data.tags?.forEach(tag => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  });
});

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);

const colors = [
  '#e94560', '#0ea5e9', '#10b981', '#f59e0b', 
  '#8b5cf6', '#ec4899', '#06b6d4', '#84cc16',
  '#f97316', '#6366f1', '#14b8a6', '#ef4444',
];

// 构建JSON数据给前端筛选用
const allItems = [
  ...posts.map(p => ({
    title: p.data.title,
    desc: p.data.description,
    url: `${base}posts/${p.id.replace(/\.md$/, '')}/`,
    date: p.data.pubDate.toLocaleDateString('zh-CN'),
    tags: p.data.tags || [],
    type: 'post' as const,
  })),
  ...ideas.map(i => ({
    title: i.data.title,
    desc: i.data.description || '',
    url: `${base}ideas/${i.id.replace(/\.md$/, '')}/`,
    date: i.data.pubDate.toLocaleDateString('zh-CN'),
    tags: ['灵感'],
    type: 'idea' as const,
  })),
  ...inventions.map(i => ({
    title: i.data.title,
    desc: i.data.description || '',
    url: `${base}inventions/${i.id.replace(/\.md$/, '')}/`,
    date: i.data.pubDate.toLocaleDateString('zh-CN'),
    tags: ['发明'],
    type: 'invention' as const,
  })),
];
---

<Base title="标签">
  <div class="tags-page">
    <h1>🏷️ 标签</h1>
    <p class="subtitle">共 {sortedTags.length} 个标签，{posts.length} 篇文章</p>
    
    <SearchBox />

    <div class="tags-cloud">
      {sortedTags.map(([tag, tagPosts], i) => {
        const color = colors[i % colors.length];
        const size = Math.min(1.6, 1 + tagPosts.length * 0.12);
        return (
          <button 
            class="tag-cloud-item"
            style={`font-size: ${size}rem; --tag-color: ${color}`}
            data-tag={tag}
          >
            {tag}
            <sup class="tag-count">{tagPosts.length}</sup>
          </button>
        );
      })}
      <button class="tag-cloud-item tag-show-all active" style="font-size: 1rem; --tag-color: var(--accent)">
        全部
      </button>
    </div>

    <div class="tags-list" id="tags-list">
      {sortedTags.map(([tag, tagPosts]) => (
        <section class="tag-section" id={tag}>
          <h2>
            <TagBadge tag={tag} size="md" />
            <span class="tag-total">{tagPosts.length} 篇</span>
          </h2>
          <div class="tag-posts">
            {tagPosts.map(post => {
              const slug = post.id.replace(/\.md$/, '');
              return (
                <article class="tag-post-item">
                  <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
                  <h3><a href={`${base}posts/${slug}/`}>{post.data.title}</a></h3>
                  <p>{post.data.description}</p>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</Base>

<script is:inline>
  (function() {
    const cloudItems = document.querySelectorAll('.tag-cloud-item[data-tag]');
    const showAllBtn = document.querySelector('.tag-show-all');
    const sections = document.querySelectorAll('.tag-section');
    
    function filterByTag(tag) {
      sections.forEach(sec => {
        if (tag === 'all' || sec.id === tag) {
          sec.style.display = '';
        } else {
          sec.style.display = 'none';
        }
      });
      
      cloudItems.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.tag === tag);
      });
      if (showAllBtn) {
        showAllBtn.classList.toggle('active', tag === 'all');
      }
      
      // 滚动到标签列表
      if (tag !== 'all') {
        const target = document.getElementById(tag);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    }
    
    cloudItems.forEach(btn => {
      btn.addEventListener('click', () => {
        filterByTag(btn.dataset.tag);
      });
    });
    
    if (showAllBtn) {
      showAllBtn.addEventListener('click', () => {
        filterByTag('all');
      });
    }
    
    // 从URL hash读取标签
    const hash = decodeURIComponent(window.location.hash.slice(1));
    if (hash && document.getElementById(hash)) {
      filterByTag(hash);
    }
  })();
</script>

<style>
  .tags-page { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 2.2rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--muted); margin-bottom: 2rem; font-size: 1rem; }
  
  .tags-cloud {
    display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;
    padding: 2rem; background: var(--card-bg); border: 1px solid var(--border);
    border-radius: 12px; margin-bottom: 3rem;
  }
  .tag-cloud-item {
    color: var(--tag-color); background: none; border: none; cursor: pointer;
    font-weight: 600; transition: all 0.2s; padding: 0.3rem 0.6rem;
    border-radius: 8px; font-family: inherit;
  }
  .tag-cloud-item:hover { transform: scale(1.05); }
  .tag-cloud-item.active {
    background: color-mix(in srgb, var(--tag-color) 12%, transparent);
    box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--tag-color) 30%, transparent);
  }
  .tag-count { font-size: 0.6em; color: var(--muted); margin-left: 0.2rem; }
  
  .tags-list { display: flex; flex-direction: column; gap: 3rem; }
  .tag-section h2 { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; font-size: 1.3rem; }
  .tag-total { font-size: 0.9rem; color: var(--muted); font-weight: normal; }
  .tag-posts { display: flex; flex-direction: column; gap: 1rem; }
  .tag-post-item { padding: 1rem 1.5rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: all 0.2s; }
  .tag-post-item:hover { transform: translateX(4px); border-color: var(--accent); }
  .tag-post-item time { font-size: 0.85rem; color: var(--muted); }
  .tag-post-item h3 { font-size: 1.1rem; margin: 0.3rem 0; }
  .tag-post-item h3 a { color: var(--text); text-decoration: none; }
  .tag-post-item h3 a:hover { color: var(--accent); }
  .tag-post-item p { color: var(--muted); font-size: 0.9rem; margin: 0; }
  
  @media (max-width: 768px) {
    .tags-cloud { padding: 1.5rem; }
  }
</style>
