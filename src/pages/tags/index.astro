// 构建标签映射
const tagMap = new Map<string, typeof posts>();
posts.forEach(post => {
  post.data.tags?.forEach(tag => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  });
});

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);

// 标签颜色
const colors = [
  '#e94560', '#0ea5e9', '#10b981', '#f59e0b', 
  '#8b5cf6', '#ec4899', '#06b6d4', '#84cc16',
  '#f97316', '#6366f1', '#14b8a6', '#ef4444',
];
---

<Base title="标签">
  <div class="tags-page">
    <h1>🏷️ 标签</h1>
    <p class="subtitle">共 {sortedTags.length} 个标签，{posts.length} 篇文章</p>
    
    <SearchBox />

    <div class="tags-cloud">
      {sortedTags.map(([tag, tagPosts], i) => {
        const color = colors[i % colors.length];
        const size = Math.min(1.8, 1 + tagPosts.length * 0.15);
        return (
          <a 
            href={`#${tag}`}
            class="tag-cloud-item"
            style={`font-size: ${size}rem; --tag-color: ${color}`}
          >
            {tag}
            <sup class="tag-count">{tagPosts.length}</sup>
          </a>
        );
      })}
    </div>

    <div class="tags-list">
      {sortedTags.map(([tag, tagPosts]) => (
        <section class="tag-section" id={tag}>
          <h2>
            <TagBadge tag={tag} size="md" />
            <span class="tag-total">{tagPosts.length} 篇</span>
          </h2>
          <div class="tag-posts">
            {tagPosts.map(post => {
              const slug = post.id.replace(/\.md$/, '');
              return (
                <article class="tag-post-item">
                  <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
                  <h3><a href={`${base}posts/${slug}/`}>{post.data.title}</a></h3>
                  <p>{post.data.description}</p>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</Base>

<style>
  .tags-page { max-width: 900px; margin: 0 auto; }
  h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--muted); margin-bottom: 2rem; font-size: 1.1rem; }
  
  .tags-cloud {
    display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;
    padding: 2rem; background: var(--card-bg); border: 1px solid var(--border);
    border-radius: 12px; margin-bottom: 3rem;
  }
  .tag-cloud-item {
    color: var(--tag-color); text-decoration: none; font-weight: 600;
    transition: all 0.2s; position: relative;
  }
  .tag-cloud-item:hover { transform: scale(1.1); color: var(--tag-color); }
  .tag-count { font-size: 0.6em; color: var(--muted); margin-left: 0.2rem; }
  
  .tags-list { display: flex; flex-direction: column; gap: 3rem; }
  .tag-section h2 { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; font-size: 1.3rem; }
  .tag-total { font-size: 0.9rem; color: var(--muted); font-weight: normal; }
  .tag-posts { display: flex; flex-direction: column; gap: 1rem; }
  .tag-post-item { padding: 1rem 1.5rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: all 0.2s; }
  .tag-post-item:hover { transform: translateX(4px); border-color: var(--accent); }
  .tag-post-item time { font-size: 0.85rem; color: var(--muted); }
  .tag-post-item h3 { font-size: 1.1rem; margin: 0.3rem 0; }
  .tag-post-item h3 a { color: var(--text); text-decoration: none; }
  .tag-post-item h3 a:hover { color: var(--accent); }
  .tag-post-item p { color: var(--muted); font-size: 0.9rem; margin: 0; }
  
  @media (max-width: 768px) {
    .tags-cloud { padding: 1.5rem; }
  }
</style>
