---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const inventions = await getCollection('inventions');
  return inventions.map(inv => ({
    params: { id: inv.id.replace(/\.md$/, '') },
    props: { inv },
  }));
}

const { inv } = Astro.props;
const { Content } = await render(inv);
---

<Base title={`${inv.data.title} - 文西的发明记录`}>
  <article class="invention-post">
    <header class="post-header">
      <div class="post-meta">
        <span class="invention-number">发明 #{String(inv.data.inventionNumber).padStart(3, '0')}</span>
        <time>{inv.data.pubDate.toLocaleDateString('zh-CN')}</time>
      </div>
      <h1>{inv.data.title}</h1>
      <p class="post-desc">{inv.data.description}</p>
      <div class="post-links">
        {inv.data.ideaId && (
          <a href={`/blog/ideas/idea-${inv.data.ideaId}/`} class="idea-link">
            💡 点子 #{inv.data.ideaId}
          </a>
        )}
        {inv.data.tags && inv.data.tags.length > 0 && (
          <div class="post-tags">
            {inv.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="navigation">
        <a href="/blog/inventions/" class="back-link">← 返回发明列表</a>
        <a href="/blog/" class="home-link">首页</a>
      </div>
    </footer>
  </article>
</Base>

<style>
  .invention-post {
    max-width: 800px;
    margin: 0 auto;
  }
  .post-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }
  .invention-number {
    background: #10b981;
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .post-meta time {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .post-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .post-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.4;
    margin-bottom: 0.6rem;
  }
  .post-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .idea-link {
    background: var(--accent);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
  }
  .idea-link:hover {
    background: var(--accent-light);
  }
  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    background: var(--border);
    color: var(--text);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.85rem;
  }
  .post-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    color: var(--text);
  }
  .post-content :global(h3) {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.8rem;
    color: var(--text);
  }
  .post-content :global(p) {
    margin-bottom: 1rem;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }
  .post-content :global(code) {
    background: var(--card-bg);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .post-content :global(pre) {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .post-content :global(blockquote) {
    border-left: 4px solid #10b981;
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .back-link,
  .home-link {
    color: var(--accent);
    font-weight: 500;
  }
  .back-link:hover,
  .home-link:hover {
    text-decoration: underline;
  }
</style>
